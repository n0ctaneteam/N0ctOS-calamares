/*================*/
/*   COMPONENTS   */
/*================*/
QComboBox, QComboBox::focused, QComboBox:on {
  color: #fff;
  background: #bf0c7d;
}

QAbstractItemView,
QListView {
  color: #ddd;
  background-color: #0f0529;
  padding: 3px;
  border: 2px solid #009cad;
  selection-background-color: #bf0c7d;
  selection-color: #fff;
}

QLineEdit {
  color: #ddd;
  background-color: #0f0529;
  padding: 3px;
  border: 2px solid #009cad;
}

QProgressBar::chunk {
  color: #000;
  background-color: #00bccd;
}


/*
* {
  font-size: 100pt;
  color:#fff;
} 
#mainApp {
  font-size: 10pt;
}
*/

#sidebarApp{
  background-color: transparent;
  border-radius: 12px;
  padding-bottom: 10px;
}
#sidebarMenuApp{
  margin-left: 10px;
  margin-right: 10px;
  margin-bottom: 10px;
  background-color: #0f0529;
  border-radius: 12px;
}
#sidebarMenuApp {
  background-color: #0f0529;
  border-radius: 12px;
}

/*--CLICK BTNs--*/
#view-button-next {
  color: #000;
  background-color: #009cad;
}
#view-button-next::hover {
  color: #000;
  background-color: #00bccd;
}
#view-button-next::disabled {
  color: #222;
  background-color: #304c5d;
}

#newVolumeGroupButton {
  color: #000;
  background-color: #009cad;
}
#newVolumeGroupButton::hover {
  color: #000;
  background-color: #00bccd;
}
#newVolumeGroupButton::disabled {
  color: #222;
  background-color: #304c5d;
}

#resizeVolumeGroupButton {
  color: #000;
  background-color: #009cad;
}
#resizeVolumeGroupButton::hover {
  color: #000;
  background-color: #00bccd;
}
#resizeVolumeGroupButton::disabled {
