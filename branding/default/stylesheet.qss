  background-color: #304c5d;
}

/*--DANGER BTNs--*/
#view-button-cancel {
  color: #ddd;
  background-color: #600f3d;
}
#view-button-cancel::hover {
  color: #000;
  background-color: #df1c8d;
}
#view-button-cancel::disabled {
